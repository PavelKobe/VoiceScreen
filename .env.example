# === Database ===
DATABASE_URL=postgresql+asyncpg://voicescreen:devpassword@localhost:5432/voicescreen
POSTGRES_PASSWORD=devpassword

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Yandex SpeechKit (STT + TTS) ===
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# === LLM (OpenRouter) ===
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=

# === Voximplant (telephony) ===
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=
VOXIMPLANT_APPLICATION_ID=
VOXIMPLANT_APPLICATION_NAME=
VOXIMPLANT_RULE_ID=
VOXIMPLANT_FROM_NUMBER=

# === Yandex Object Storage (S3) ===
YOS_ACCESS_KEY=
YOS_SECRET_KEY=
YOS_BUCKET=voicescreen-recordings
YOS_ENDPOINT=https://storage.yandexcloud.net

# === App ===
APP_ENV=development
LOG_LEVEL=debug
# VoxEngine screening.js connects back here — must be publicly reachable wss://
PUBLIC_WS_URL=wss://voicescreen.example.com/api/v1/ws/call
